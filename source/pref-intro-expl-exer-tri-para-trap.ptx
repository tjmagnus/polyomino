<diagram xmlns="https://prefigure.org" width="540" height="360" margins="5">
  <coordinates bbox="(-1,-2,30,18)">
    <triangle vertices="((1,15),(7,15),(7,1))" labels="A,D,C" fill-opacity="0.7"
              fill="steelblue"
             closed="yes"
             stroke="black" 
              show-vertices="yes" point-fill="black"/>
    <polygon points="((1,15),(1,1),(7,1))" dash="6 6" stroke="gray"/>
    <point p="(1,1)" size="4" fill="black" alignment="sw"><m>B</m></point>
      <label anchor="(4,17)" alignment="c"><m>\Delta ADC</m></label>
      <label anchor="(4,15)" alignment="n" scale="0.8">6 cm.</label>
      <label anchor="(7,8)" alignment="e" scale="0.8">14 cm.</label>

<!--parallelogram starts here -->
    <polygon points="(11,15),(21,15),(25,9),(15,9)" labels="E,F,G,H" alignments="nw,n,s,sw" fill-opacity="0.5" 
              fill="red" closed="yes" stroke="black"/>
      <point p="(11,15)" size="4" fill="black" alignment="n"><m>E</m></point>
      <point p="(25,9)" size="4" fill="black" alignment="e"><m>G</m></point>
      <point p="(21,15)" size="4" fill="black" alignment="n"><m>F</m></point>
      <point p="(15,9)" size="4" fill="black" alignment="w"><m>H</m></point>
      <label anchor="(20,9)" scale="0.8" alignment="s">10 cm.</label>
    
    <point p="(25,15)" size="4" fill="black" alignment="ne"><m>N</m></point>
    <point p="(15,15)" size="4" fill="black" alignment="n"><m>M</m></point>

    <path start="(15,15)" dash="6 6" stroke="gray">
      <lineto point="(15,9)"/>
      </path>
    <path start="(21,15)" dash="6 6" stroke="gray">
       <horizontal distance="4"/>
       <vertical distance="-6"/>
      </path>
      <label anchor="(25,12)" scale="0.8" alignment="e">6 cm.</label>
      <label anchor="(23,15)" scale="0.8" alignment="n">4 cm.</label>
    <label anchor="(16,17)" alignment="c"><b>Parallelogram</b> <m>EFGH</m></label>

<!--trapezoid starts here-->
  <polygon points="(10,1),(16,7),(26,7),(26,1)" labels="J,I,L,K" alignments="sw,nw,ne,se" fill-opacity="0.4" 
              fill="lightgreen" closed="yes" stroke="black"/>
    <point p="(10,1)" size="4" fill="black" alignment="sw"><m>J</m></point>
    <point p="(16,7)" size="4" fill="black" alignment="w"><m>I</m></point>
    <point p="(26,7)" size="4" fill="black" alignment="e"><m>L</m></point>
    <point p="(26,1)" size="4" fill="black" alignment="se"><m>K</m></point>
    <point p="(16,1)" size="4" fill="black" alignment="ne"><m>O</m></point>  
  <path start="(16,7)" dash="6 6" stroke="gray">
       <vertical distance="-6"/>
      </path>
      <label anchor="(13,1)" scale="0.8" alignment="n">6 cm.</label>
      <label anchor="(21,1)" scale="0.8" alignment="n">10 cm.</label>
      <label anchor="(21,7)" scale="0.8" alignment="s">10 cm.</label>
      <label anchor="(26,4)" scale="0.8" alignment="e">6 cm.</label>
      <label anchor="(16,0.7)" scale="0.8" alignment="s">16 cm.</label>
      <label anchor="(18,-1)" alignment="c" ><b>Trapezoid</b> <m>IJKL</m></label>>

  </coordinates>
</diagram>